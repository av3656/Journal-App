<configuration>

    <appender name="myConsoleAppender"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                %d{HH:mm:ss} [%thread] %-5level %logger - %msg%n
            </pattern>
        </encoder>

    </appender>

    <appender name="myFileAppender"
              class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>log/journalApp.log</file>

        <rollingPolicy
                class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">

            <fileNamePattern>
                log/journalApp-%d{yyyy-MM-dd_HH-mm}.%i.log
            </fileNamePattern>

            <maxFileSize>10MB</maxFileSize>

            <maxHistory>10</maxHistory>

            <totalSizeCap>1GB</totalSizeCap>

        </rollingPolicy>

        <encoder>
            <pattern>
                %d{yy-MM-dd HH:mm:ss} [%thread] %-5level %logger - %msg%n
            </pattern>
        </encoder>

    </appender>

    <root level="INFO">

        <appender-ref ref="myConsoleAppender"/>
        <appender-ref ref="myFileAppender"/>

    </root>

</configuration>